# ! Production note: copy this file to `.env` and replace every placeholder before deployment.
PORT=5000
NODE_ENV=production
TRUST_PROXY=1
SITE_URL=https://your-domain.com

# ! Production note: set this to your deployed frontend origin, or a comma-separated list of allowed origins.
CORS_ORIGIN=https://your-domain.com

# ! Production note: use a real MySQL user with least-privilege access.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nova_app
DB_PASSWORD=change-me
DB_NAME=nova_tutor_db
DB_CONNECTION_LIMIT=10

# ! Production note: leave this false in production unless you are applying a controlled migration.
SYNC_SCHEMA_ON_START=false

# ! Production note: configure a real SMTP provider and set MAIL_FROM to a branded sender address.
MAIL_SERVICE=gmail
MAIL_HOST=
MAIL_PORT=
MAIL_SECURE=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ! Production note: prefer database-backed admin accounts with strong passwords in production.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_HOURS=8
ADMIN_COOKIE_SECURE=true
